# Susurrus environment variables.
#
# Susurrus auto-loads ONE of these on startup, in this order:
#   1. local/.env     (preferred — sits alongside your local/ profiles, gitignored)
#   2. .env           (project-root fallback, also gitignored)
#
# Existing shell env vars always win over what's in the file
# (load happens with override=False).
#
# Copy this file to start:
#   cp .env.example local/.env
#   # ...fill in real values...


# ── API keys ──────────────────────────────────────────────────────────────
# Required for any Anthropic-backed feature: advisor commentary, term lookup,
# and Q&A. Without it those steps raise on first API call; transcription
# itself still runs.
ANTHROPIC_API_KEY=sk-ant-...


# ── Pipeline config overrides ─────────────────────────────────────────────
# Every field in config.py:Config can be overridden by setting an env var
# named SUSURRUS_<FIELD_UPPER>. Uncomment any you want to override.

# ── Audio capture
# SUSURRUS_ICECAST_PORT=8000
# SUSURRUS_CAPTURE_MODE=icecast        # or "tcp"

# ── Whisper (transcription)
# SUSURRUS_WHISPER_MODEL=large-v3      # or small.en, distil-large-v3, etc.
# SUSURRUS_WHISPER_DEVICE=cuda         # or cpu, mps
# SUSURRUS_WHISPER_COMPUTE_TYPE=float16 # or int8 on cpu, float16 on cuda
# SUSURRUS_WHISPER_LANGUAGE=en
# SUSURRUS_WHISPER_BEAM_SIZE=5

# ── Ollama (continuation merge + monitor profiles)
# SUSURRUS_OLLAMA_URL=http://localhost:11434/api/chat
# SUSURRUS_OLLAMA_MODEL=qwen2.5:14b
# SUSURRUS_OLLAMA_NO_THINK=false

# ── Anthropic (advisor, term lookup, Q&A)
# SUSURRUS_ANTHROPIC_MODEL=claude-sonnet-4-6

# ── Web UI
# SUSURRUS_WEB_PORT=8765

# ── Paragraph break tuning (controls how often advisor fires)
# Paragraphs finalize every (base + random 0..jitter) "counted" sentences.
# Sentences shorter than min_words don't count.
# SUSURRUS_PARA_BREAK_BASE=6
# SUSURRUS_PARA_BREAK_JITTER=3
# SUSURRUS_PARA_BREAK_MIN_WORDS=5

# ── VAD tuning (usually leave at defaults)
# SUSURRUS_VAD_THRESHOLD=0.5
# SUSURRUS_VAD_SILENCE_DURATION_MS=600
# SUSURRUS_VAD_MIN_SPEECH_MS=300
# SUSURRUS_VAD_LOOKBACK_MS=500
# SUSURRUS_VAD_MAX_UTTERANCE_S=30.0
# SUSURRUS_VAD_SOFT_SPLIT_S=10.0
# SUSURRUS_VAD_SOFT_SPLIT_THRESHOLD=0.7
# SUSURRUS_SAMPLE_RATE=16000
# SUSURRUS_VAD_CHUNK_SAMPLES=512
